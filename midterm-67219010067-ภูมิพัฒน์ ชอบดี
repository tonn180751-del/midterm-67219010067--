<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ต้นน้ำ | Midterm Project</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Noto+Sans+Thai:wght@400;500;700&family=Permanent+Marker&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-navy: #12142b;
    --bg-navy-2: #1b1f3f;
    --cork: #2a2450;
    --violet: #8b6bff;
    --cyan: #4fd8d0;
    --pink-tape: #ff8fb3;
    --paper: #f6f1e4;
    --star: #ffe98a;
  }

  *{box-sizing:border-box;}

  body{
    margin:0;
    font-family:"Noto Sans Thai", sans-serif;
    background:
      radial-gradient(circle at 20% 10%, rgba(139,107,255,0.18), transparent 40%),
      radial-gradient(circle at 85% 30%, rgba(79,216,208,0.14), transparent 45%),
      var(--bg-navy);
    color:var(--paper);
    min-height:100vh;
    overflow-x:hidden;
    position:relative;
  }

  /* twinkling stars */
  .stars{
    position:fixed; inset:0; z-index:0; pointer-events:none;
    background-image:
      radial-gradient(1.5px 1.5px at 10% 20%, #fff, transparent),
      radial-gradient(1.5px 1.5px at 80% 15%, #fff, transparent),
      radial-gradient(1px 1px at 60% 60%, #fff, transparent),
      radial-gradient(1px 1px at 30% 80%, #fff, transparent),
      radial-gradient(1.5px 1.5px at 90% 70%, #fff, transparent),
      radial-gradient(1px 1px at 45% 35%, #fff, transparent);
    opacity:0.5;
    animation: twinkle 5s ease-in-out infinite alternate;
  }
  @keyframes twinkle{ from{opacity:0.25;} to{opacity:0.65;} }

  .string-lights{
    position:relative; z-index:2;
    height:46px;
    background-repeat:repeat-x;
    background-size:60px 46px;
    background-image:
      radial-gradient(circle 5px at 30px 6px, var(--star) 60%, transparent 62%);
    margin-bottom:-10px;
  }
  .string-lights::before{
    content:"";
    position:absolute; top:0; left:0; right:0; height:2px;
    background:repeating-linear-gradient(90deg, #4a4570 0 40px, transparent 40px 60px);
  }

  .container{
    max-width:1000px;
    margin:0 auto;
    padding:10px 20px 60px;
    position:relative;
    z-index:1;
  }

  h1,h2,h3,h4{ font-family:"Baloo 2", "Noto Sans Thai", sans-serif; margin:0; }

  .eyebrow{
    font-family:"Permanent Marker", cursive;
    color:var(--pink-tape);
    font-size:0.95rem;
    letter-spacing:0.5px;
  }

  /* ===== Profile / poster card ===== */
  .profile-section{
    display:flex;
    gap:28px;
    align-items:center;
    background:linear-gradient(160deg, var(--bg-navy-2), #211a44);
    border:1px solid rgba(139,107,255,0.35);
    border-radius:20px;
    padding:32px;
    margin-top:24px;
    box-shadow:0 20px 50px rgba(0,0,0,0.35);
    position:relative;
  }
  .profile-section::after{
    content:"MIDTERM ✦ 20 pts";
    position:absolute;
    top:-14px; right:24px;
    background:var(--violet);
    color:#12142b;
    font-family:"Baloo 2";
    font-weight:800;
    font-size:0.75rem;
    padding:6px 14px;
    border-radius:999px;
    transform:rotate(4deg);
    box-shadow:0 6px 14px rgba(139,107,255,0.4);
  }
  .avatar{
    flex-shrink:0;
    width:130px; height:130px;
    border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-family:"Baloo 2"; font-weight:800; font-size:3rem;
    color:#12142b;
    background:conic-gradient(from 200deg, var(--cyan), var(--violet), var(--pink-tape), var(--cyan));
    border:4px solid var(--paper);
    box-shadow:0 0 0 6px rgba(139,107,255,0.25);
    overflow:hidden;
  }
  .avatar img{
    width:100%; height:100%;
    object-fit:cover;
  }
  .profile-info h1{
    font-size:2.1rem;
    color:var(--paper);
  }
  .profile-info .nickname{
    display:inline-block;
